# Copy to deploy/.env.prod (gitignored) and fill in.
DOMAIN=sheepshead.example.com
POSTGRES_USER=sheepshead
POSTGRES_PASSWORD=change-me-to-something-long-and-random
SHEEPSHEAD_MODEL_LABEL=pfsp-swish-v30M-2025-12
# Host path to the model checkpoint (mounted read-only into the api container).
MODEL_FILE=./final_pfsp_swish_ppo.pt
