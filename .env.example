SHEEPSHEAD_MODEL_PATH=./final_pfsp_swish_ppo.pt
SHEEPSHEAD_CORS_ORIGINS=http://localhost:3000
ENV=development
LOG_FORMAT=text

# Postgres connection used by the server at runtime.
DATABASE_URL=postgres://sheepshead:sheepshead@localhost:5433/sheepshead

# Used by graphile-migrate (dev/CI only — never set these in production).
SHADOW_DATABASE_URL=postgres://sheepshead:sheepshead@localhost:5433/sheepshead_shadow
ROOT_DATABASE_URL=postgres://sheepshead:sheepshead@localhost:5433/postgres
